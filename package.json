{
  "name": "agentx",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @agentx/db generate",
    "db:migrate": "pnpm --filter @agentx/db migrate",
    "db:seed": "pnpm --filter @agentx/db seed",
    "db:reset": "pnpm --filter @agentx/db reset",
    "db:studio": "pnpm --filter @agentx/db studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
